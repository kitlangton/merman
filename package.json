{
  "name": "@kitlangton/merman",
  "version": "0.0.0",
  "description": "Mermaid-flavored flowchart, sequence, and state diagrams for OpenTUI terminals.",
  "keywords": [
    "ansi",
    "cli",
    "diagram",
    "diagrams",
    "flowchart",
    "mermaid",
    "opentui",
    "sequence-diagram",
    "state-diagram",
    "terminal",
    "tui"
  ],
  "homepage": "https://github.com/kitlangton/merman#readme",
  "bugs": {
    "url": "https://github.com/kitlangton/merman/issues"
  },
  "license": "MIT",
  "author": "Kit Langton",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitlangton/merman.git"
  },
  "bin": {
    "merman": "./dist/cli/main.mjs"
  },
  "workspaces": {
    "packages": [
      "examples"
    ],
    "catalog": {
      "effect": "4.0.0-beta.59"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun run test",
    "typecheck": "tsc --noEmit && tsc -p examples/tsconfig.json --noEmit",
    "attw": "attw --pack . --profile esm-only",
    "publint": "publint",
    "validate": "bun run build && bun run publint && bun run attw",
    "prepublishOnly": "bun run build && bun run typecheck && bun run test && bun run validate",
    "examples": "bun examples/src/index.ts",
    "examples:flowchart": "bun examples/src/flowchart-demo.ts",
    "examples:state": "bun examples/src/state-diagram-demo.ts",
    "examples:sequence": "bun examples/src/sequence-diagram-demo.ts"
  },
  "dependencies": {
    "effect": "catalog:",
    "string-width": "7.2.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@opentui/core": "0.2.2",
    "@types/bun": "latest",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "publint": "^0.3.16",
    "tsdown": "^0.18.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.2.2"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  },
  "packageManager": "bun@1.3.13"
}
