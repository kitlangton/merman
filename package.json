{
  "name": "opentui-diagrams",
  "version": "0.0.0",
  "description": "Experimental diagram renderers for OpenTUI",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "examples"
  ],
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc -p examples/tsconfig.json --noEmit",
    "examples:flowchart": "bun examples/src/flowchart-demo.ts",
    "examples:state": "bun examples/src/state-diagram-demo.ts",
    "examples:sequence": "bun examples/src/sequence-diagram-demo.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT",
  "peerDependencies": {
    "@opentui/core": ">=0.2.2"
  },
  "dependencies": {
    "string-width": "7.2.0"
  },
  "devDependencies": {
    "@opentui/core": "0.2.2",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
